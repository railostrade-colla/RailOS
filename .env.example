# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Railos

# Email (لاحقاً)
RESEND_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Push Notifications (Web Push / VAPID)
# ───────────────────────────────────────────────────────────────
# Generate the keypair once with:
#   npx web-push generate-vapid-keys
# Then copy the values into your local `.env.local` (NOT this file).
# ⚠ VAPID_PRIVATE_KEY is SECRET — never commit it to git.
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:railostrade@gmail.com

# ═══════════════════════════════════════════════════════════════
# Sentry — Error monitoring (https://sentry.io — free 5K errors/mo)
# ───────────────────────────────────────────────────────────────
# 1) Create a free account → New Project → choose "Next.js"
# 2) Copy the DSN below (required to capture errors)
# 3) (optional) Create an Auth Token + add ORG/PROJECT to enable
#    automatic source-map upload — gives unminified stack traces.
# Without ANY of these, the app keeps working as a no-op.
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
